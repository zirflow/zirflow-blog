---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
}
const { title, description, ogImage, canonical } = Astro.props;
const pageTitle = title.includes('Zirflow') ? title : `${title} · Zirflow Blog`;
const canonicalUrl = canonical || Astro.url.href;
const defaultOgImage = 'https://blog.zirflow.com/favicon.svg';
const ogImageProp = ogImage || defaultOgImage;
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{pageTitle}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Zirflow Blog" />
  <meta property="og:image" content={ogImageProp} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="alternate" type="application/rss+xml" title="Zirflow Blog RSS" href="/rss.xml" />
  <meta name="theme-color" content="#07090f" />
  <script>
    document.documentElement.classList.add('js-ready');
  </script>
</head>
<body>
  <a href="#main-content" class="skip-link" style="position:absolute;top:-100px;left:8px;padding:8px 16px;background:var(--accent);color:#fff;z-index:9999;border-radius:0 0 8px 8px;text-decoration:none;font:14px/1 var(--font-body)">
    跳到内容
  </a>
  <Header />
  <main id="main-content">
    <slot />
  </main>
  <Footer />
</body>
</html>
