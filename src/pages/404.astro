---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面未找到 · Zirflow Blog" description="页面未找到">
  <section class="not-found">
    <h1 class="not-found-code">404</h1>
    <p class="not-found-msg">页面未找到</p>
    <p class="not-found-desc">你访问的页面不存在或已被移除。</p>
    <a href="/" class="not-found-link">← 返回博客首页</a>
  </section>
</BaseLayout>

<style>
.not-found {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  text-align: center;
  padding: 40px 20px;
}
.not-found-code {
  font-size: clamp(96px, 20vw, 160px);
  font-weight: 900;
  line-height: 1;
  background: linear-gradient(135deg, #4d8dff, #b48bff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin: 0 0 16px;
  letter-spacing: -0.04em;
}
.not-found-msg {
  font-size: 24px;
  font-weight: 700;
  color: var(--fg);
  margin: 0 0 8px;
}
.not-found-desc {
  font-size: 15px;
  color: var(--muted);
  margin: 0 0 32px;
}
.not-found-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 12px 28px;
  border-radius: 10px;
  background: linear-gradient(135deg, #4d8dff, #2a6cf0);
  color: #fff;
  font-weight: 600;
  font-size: 15px;
  text-decoration: none;
  transition: opacity 0.2s;
}
.not-found-link:hover {
  opacity: 0.9;
  text-decoration: none;
}
</style>
