---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { sortPostsByDate } from '../../utils';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const allTags = [...new Set(posts.flatMap(p => p.data.tags || []))];
  return allTags.map(tag => ({
    params: { tag },
    props: { tag, posts: posts.filter(p => p.data.tags?.includes(tag)) },
  }));
}

export interface Props {
  tag: string;
  posts: CollectionEntry<'posts'>[];
}
const { tag, posts } = Astro.props;
const sorted = sortPostsByDate(posts);
---

<BaseLayout
  title={`#${tag} · Zirflow Blog`}
  description={`关于「${tag}」的 AI 自动化实战文章`}
>
  <section class="wrap wrap-wide" style="padding: 40px 0">
    <h1 style="margin-bottom:8px"># {tag}</h1>
    <p class="muted" style="margin-bottom:32px">{posts.length} 篇文章</p>
    {sorted.length > 0 ? (
      sorted.map(post => <PostCard post={post} />)
    ) : (
      <p class="muted">暂无文章</p>
    )}
  </section>
</BaseLayout>
